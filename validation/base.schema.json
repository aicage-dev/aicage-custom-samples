{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "AICAGE custom base definition",
  "type": "object",
  "required": [
    "from_image",
    "base_image_distro",
    "base_image_description",
    "architectures"
  ],
  "properties": {
    "from_image": {
      "type": "string",
      "pattern": ".*\\S.*"
    },
    "base_image_distro": {
      "type": "string",
      "pattern": ".*\\S.*"
    },
    "base_image_description": {
      "type": "string",
      "pattern": ".*\\S.*"
    },
    "architectures": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "amd64",
          "arm64"
        ]
      },
      "uniqueItems": true,
      "minItems": 1
    },
    "build_local": {
      "type": "boolean",
      "default": false
    }
  },
  "additionalProperties": false
}
