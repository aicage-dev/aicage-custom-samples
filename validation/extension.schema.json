{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "AICAGE extension definition",
  "type": "object",
  "required": [
    "name",
    "description"
  ],
  "properties": {
    "name": {
      "type": "string",
      "pattern": ".*\\S.*"
    },
    "description": {
      "type": "string",
      "pattern": ".*\\S.*"
    },
    "shares": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": ".*\\S.*"
      }
    }
  },
  "additionalProperties": false
}
